{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "functions": {
    "api/**": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/admin", "destination": "/admin" },
    { "source": "/admin/(.*)", "destination": "/admin" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
