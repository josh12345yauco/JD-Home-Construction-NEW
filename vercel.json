{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "functions": {
    "api/upload.ts": {
      "maxRequestBodyLength": 52428800
    }
  },
  "rewrites": [
    { "source": "/admin", "destination": "/admin" },
    { "source": "/admin/(.*)", "destination": "/admin" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
